# Application
DEBUG=False
APP_NAME=Agent Eddy
APP_VERSION=1.0.0

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=edi_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# AI/ML
OPENAI_API_KEY=
AI_MODEL=gpt-4
AI_CONFIDENCE_THRESHOLD_HIGH=0.90
AI_CONFIDENCE_THRESHOLD_MEDIUM=0.75

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Slack (optional - can also be set via Settings UI)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx

# EDI Identity - used to auto-detect Inbound (receiver=our_id) vs Outbound (sender=our_id)
# OUR_COMPANY_ISA_ID=ACME_CORP
